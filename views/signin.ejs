<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Sign In — GetRallied</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;background:#fff;color:#111;min-height:100vh;display:flex;flex-direction:column}
    nav{border-bottom:1px solid #e5e2dc;padding:16px 32px;display:flex;align-items:center;justify-content:space-between}
    nav img{height:28px}
    nav .links{display:flex;gap:20px;align-items:center}
    nav a{color:#777;text-decoration:none;font-size:14px;font-weight:600}
    nav a:hover{color:#111}
    .wrap{flex:1;display:flex;align-items:center;justify-content:center;padding:40px 24px}
    .card{background:#fff;border:1.5px solid #e5e2dc;border-radius:8px;padding:40px;max-width:400px;width:100%}
    h1{font-size:22px;font-weight:800;text-align:center;margin-bottom:6px;letter-spacing:-0.3px}
    .sub{color:#777;text-align:center;margin-bottom:28px;font-size:14px}
    .error{background:#fef2f2;color:#b91c1c;padding:10px 14px;border-radius:6px;font-size:13px;margin-bottom:16px;border:1px solid #fecaca}
    label{display:block;font-size:12px;font-weight:600;color:#777;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px}
    input[type=email],input[type=password]{width:100%;padding:11px 14px;border-radius:4px;border:1.5px solid #e5e2dc;background:#fff;color:#111;font-size:15px;font-family:inherit;margin-bottom:16px}
    input:focus{outline:none;border-color:#111}
    input::placeholder{color:#bbb}
    .btn{width:100%;padding:13px;border:none;background:#111;color:#fff;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;letter-spacing:-0.2px}
    .btn:hover{background:#333}
    .alt{text-align:center;margin-top:20px;font-size:14px;color:#777}
    .alt a{color:#111;text-decoration:none;font-weight:700}
    .alt a:hover{text-decoration:underline}
    .magic{text-align:center;margin-top:10px;font-size:13px;color:#aaa}
    .magic a{color:#777;text-decoration:none}
    .magic a:hover{color:#111}
  </style>
</head>
<body>
  <%- include("partials/nav", { _navActive: "" }) %>
  <div class="wrap">
    <div class="card">
      <h1>Welcome back</h1>
      <p class="sub">Sign in to manage your events.</p>
      <% if (error) { %><div class="error"><%= error %></div><% } %>
      <form method="POST" action="/signin">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>">
        <input type="hidden" name="next" value="<%= next %>">
        <label>Email</label>
        <input type="email" name="email" placeholder="you@example.com" required>
        <label>Password</label>
        <input type="password" name="password" required>
        <button type="submit" class="btn">Sign In</button>
      </form>
      <p class="alt">Don't have an account? <a href="/signup">Sign up</a></p>
      <p class="magic"><a href="/login">Or use a magic link →</a></p>
    </div>
  </div>
</body>
</html>
