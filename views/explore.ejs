<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<link rel="icon" href="/favicon.ico"><link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <title>Explore Events — GetRallied</title>
<meta name="description" content="Browse public events and find ways to help out in your community.">
<meta property="og:title" content="Explore Events — GetRallied">
<meta property="og:description" content="Browse public events and sign up to help.">
<meta property="og:type" content="website">
<meta property="og:url" content="https://getrallied.com/explore">
<meta property="og:image" content="https://getrallied.com/logo.png">
<meta name="twitter:card" content="summary">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;background:#fff;color:#111;min-height:100vh}
    nav{border-bottom:1px solid #e5e2dc;padding:16px 32px;display:flex;align-items:center;gap:20px}
    nav img{height:28px}
    nav .spacer{flex:1}
    nav a{color:#777;text-decoration:none;font-size:14px;font-weight:600}
    nav a:hover{color:#111}
    nav .active{color:#111}
    .container{max-width:880px;margin:0 auto;padding:40px 24px}
    h1{font-size:24px;font-weight:800;letter-spacing:-0.5px;margin-bottom:6px}
    .sub{color:#777;font-size:15px;margin-bottom:24px}
    .filters{display:flex;gap:10px;margin-bottom:28px;flex-wrap:wrap;align-items:center}
    .search{flex:1;min-width:200px;padding:10px 14px;border-radius:4px;border:1.5px solid #e5e2dc;background:#fff;color:#111;font-size:14px;font-family:inherit}
    .search:focus{outline:none;border-color:#111}
    .search::placeholder{color:#bbb}
    .sort-btn{padding:7px 14px;border-radius:4px;border:1.5px solid #e5e2dc;background:#fff;color:#777;font-size:13px;font-family:inherit;cursor:pointer;text-decoration:none;font-weight:600}
    .sort-btn.active{background:#111;color:#fff;border-color:#111}
    .sort-btn:hover{border-color:#111;color:#111}
    .sort-btn.active:hover{color:#fff}
    .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px}
    .event-card{border:1.5px solid #e5e2dc;border-radius:6px;overflow:hidden;transition:border-color .2s}
    .event-card:hover{border-color:#111}
    .event-card a{text-decoration:none;color:inherit;display:block}
    .card-banner{width:100%;height:140px;object-fit:cover;background:#f7f6f4}
    .card-body{padding:16px}
    .card-title{font-size:15px;font-weight:800;margin-bottom:5px;letter-spacing:-0.2px}
    .card-meta{font-size:12px;color:#777;margin-bottom:10px}
    .card-desc{font-size:13px;color:#999;line-height:1.5;margin-bottom:12px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .card-stats{display:flex;gap:14px;font-size:12px;color:#777}
    .progress-bar{width:100%;height:3px;background:#e5e2dc;border-radius:2px;margin-top:10px;overflow:hidden}
    .progress-fill{height:100%;background:#111;border-radius:2px}
    .empty{text-align:center;padding:60px 20px}
    .empty h2{font-size:18px;font-weight:700;margin-bottom:8px;color:#777}
    .empty p{color:#aaa;font-size:14px}
  </style>
</head>
<body>
  <%- include("partials/nav", { _navActive: "explore" }) %>
  <div class="container">
    <h1>Explore Events</h1>
    <p class="sub">Find events near you and show up where it matters.</p>

    <form class="filters" method="GET" action="/explore" id="explore-form">
      <input type="text" name="q" class="search" placeholder="Search events..." value="<%= q %>" style="flex:1;min-width:160px">
      <input type="text" name="location" class="search" placeholder="📍 City or ZIP..." value="<%= typeof locationQ !== 'undefined' ? locationQ : '' %>" style="flex:0.7;min-width:140px">
      <input type="hidden" name="lat" id="geo-lat" value="<%= typeof searchLat !== 'undefined' && searchLat ? searchLat : '' %>">
      <input type="hidden" name="lon" id="geo-lon" value="<%= typeof searchLon !== 'undefined' && searchLon ? searchLon : '' %>">
      <select name="radius" class="sort-btn" style="padding:7px 10px;cursor:pointer">
        <option value="25" <%= (typeof radius !== 'undefined' && radius == 25) ? 'selected' : '' %>>25 mi</option>
        <option value="50" <%= (typeof radius === 'undefined' || radius == 50) ? 'selected' : '' %>>50 mi</option>
        <option value="100" <%= (typeof radius !== 'undefined' && radius == 100) ? 'selected' : '' %>>100 mi</option>
        <option value="250" <%= (typeof radius !== 'undefined' && radius == 250) ? 'selected' : '' %>>250 mi</option>
      </select>
      <button type="button" class="sort-btn" onclick="useMyLocation()" title="Use my location" style="cursor:pointer">📍 Near Me</button>
      <button type="submit" class="sort-btn" style="background:#111;color:#fff;border-color:#111;cursor:pointer">Search</button>
    </form>
    <div class="filters" style="margin-top:-16px;margin-bottom:20px;gap:6px">
      <a href="/explore?q=<%= encodeURIComponent(q) %>&location=<%= encodeURIComponent(typeof locationQ !== 'undefined' ? locationQ : '') %>&sort=newest" class="sort-btn <%= sort === 'newest' ? 'active' : '' %>">Newest</a>
      <a href="/explore?q=<%= encodeURIComponent(q) %>&location=<%= encodeURIComponent(typeof locationQ !== 'undefined' ? locationQ : '') %>&sort=soonest" class="sort-btn <%= sort === 'soonest' ? 'active' : '' %>">Soonest</a>
      <a href="/explore?q=<%= encodeURIComponent(q) %>&location=<%= encodeURIComponent(typeof locationQ !== 'undefined' ? locationQ : '') %>&sort=popular" class="sort-btn <%= sort === 'popular' ? 'active' : '' %>">Most Popular</a>
      <% if (typeof locationQ !== 'undefined' && locationQ) { %>
        <a href="/explore?q=<%= encodeURIComponent(q) %>" class="sort-btn" style="color:#c00;border-color:#fcc">✕ Clear location</a>
      <% } %>
    </div>

    <% if (events.length === 0) { %>
      <div class="empty">
        <h2>No public events yet</h2>
        <p><%= q ? 'Try a different search.' : 'Be the first to create one!' %></p>
      </div>
    <% } else { %>
      <div class="grid">
        <% events.forEach(e => { %>
          <div class="event-card">
            <a href="/event/<%= e.id %>">
              <% if (e.banner_image) { %>
                <img src="<%= e.banner_image %>" class="card-banner">
              <% } else { %>
                <div class="card-banner" style="display:flex;align-items:center;justify-content:center;font-size:40px;color:#bbb">📣</div>
              <% } %>
              <div class="card-body">
                <div class="card-title"><%= e.title %></div>
                <div class="card-meta">
                  📅 <%= e.date || 'Date TBD' %> · 📍 <%= e.location || 'Location TBD' %>
                  <% if (e.distance !== null && e.distance !== undefined) { %>
                    · <strong><%= e.distance %> mi away</strong>
                  <% } %>
                </div>
                <% if (e.vision) { %>
                  <div class="card-desc"><%= e.vision %></div>
                <% } %>
                <div class="card-stats">
                  <span>📋 <%= e.taskCount %> tasks</span>
                  <span>🙋 <%= e.claimCount %> people</span>
                  <span><%= e.totalNeeded > 0 ? Math.round(e.totalClaimed / e.totalNeeded * 100) : 0 %>% filled</span>
                </div>
                <div class="progress-bar">
                  <div class="progress-fill" style="width:<%= e.totalNeeded > 0 ? Math.min(100, Math.round(e.totalClaimed / e.totalNeeded * 100)) : 0 %>%"></div>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
  <script>
  function useMyLocation() {
    if (!navigator.geolocation) return alert('Geolocation not supported by your browser');
    const btn = event.target;
    btn.textContent = '⏳ Locating...';
    navigator.geolocation.getCurrentPosition(
      pos => {
        document.getElementById('geo-lat').value = pos.coords.latitude;
        document.getElementById('geo-lon').value = pos.coords.longitude;
        // Clear text location since we're using coordinates
        document.querySelector('input[name="location"]').value = 'My Location';
        document.getElementById('explore-form').submit();
      },
      err => { btn.textContent = '📍 Near Me'; alert('Could not get your location. Try searching by city instead.'); }
    );
  }
  </script>
</body>
</html>
