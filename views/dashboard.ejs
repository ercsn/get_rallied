<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<link rel="icon" href="/favicon.ico"><link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <title>Dashboard — GetRallied</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;background:#fff;color:#111;min-height:100vh}
    nav{border-bottom:1px solid #e5e2dc;padding:16px 32px;display:flex;align-items:center;gap:20px}
    nav img{height:28px}
    nav .spacer{flex:1}
    nav a{color:#777;text-decoration:none;font-size:14px;font-weight:600}
    nav a:hover{color:#111}
    nav .name{color:#111;font-weight:700;font-size:14px}
    .container{max-width:880px;margin:0 auto;padding:40px 24px}
    h1{font-size:24px;font-weight:800;letter-spacing:-0.5px;margin-bottom:6px}
    .sub{color:#777;font-size:15px;margin-bottom:28px}
    .btn-create{display:inline-block;background:#111;color:#fff;padding:11px 24px;font-weight:700;font-size:14px;text-decoration:none;margin-bottom:32px;letter-spacing:-0.2px}
    .btn-create:hover{background:#333}
    .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px}
    .event-card{border:1.5px solid #e5e2dc;border-radius:6px;overflow:hidden;transition:border-color .2s}
    .event-card:hover{border-color:#111}
    .event-card a{text-decoration:none;color:inherit;display:block}
    .card-banner{width:100%;height:120px;object-fit:cover;background:#f7f6f4}
    .card-body{padding:16px}
    .card-title{font-size:15px;font-weight:800;margin-bottom:5px;letter-spacing:-0.2px}
    .card-meta{font-size:12px;color:#777;margin-bottom:12px}
    .card-stats{display:flex;gap:14px;font-size:12px;color:#777}
    .progress-bar{width:100%;height:3px;background:#e5e2dc;border-radius:2px;margin-top:10px;overflow:hidden}
    .progress-fill{height:100%;background:#111;border-radius:2px;transition:width .3s}
    .empty{text-align:center;padding:60px 20px}
    .empty h2{font-size:18px;font-weight:700;margin-bottom:8px;color:#777}
    .empty p{color:#aaa;font-size:14px}
    .badge{display:inline-block;background:#fef3c7;color:#92400e;padding:2px 7px;border-radius:3px;font-size:11px;font-weight:700;margin-left:6px}
    .badge-private{background:#f3f4f6;color:#777}
  </style>
</head>
<body>
  <%- include("partials/nav", { _navActive: "dashboard" }) %>
  <div class="container">
    <h1>Your Events</h1>
    <p class="sub">Manage your events and see who's rallying.</p>
    <a href="/create" class="btn-create">+ Create New Event</a>

    <% if (events.length === 0) { %>
      <div class="empty">
        <h2>No events yet</h2>
        <p>Create your first event and start rallying people.</p>
        <a href="/create" class="btn-create" style="margin-top:20px;display:inline-block">🚀 Create Your First Event</a>
      </div>
    <% } else { %>
      <div class="grid">
        <% events.forEach(e => { %>
          <div class="event-card">
            <a href="/organizer/<%= e.organizer_token %>">
              <% if (e.banner_image) { %>
                <img src="<%= e.banner_image %>" class="card-banner">
              <% } else { %>
                <div class="card-banner" style="display:flex;align-items:center;justify-content:center;font-size:32px;color:#bbb">📣</div>
              <% } %>
              <div class="card-body">
                <div class="card-title">
                  <%= e.title %>
                  <% if (e.is_private) { %><span class="badge badge-private">🔒 Private</span><% } %>
                  <% if (e.pendingCount > 0) { %><span class="badge"><%= e.pendingCount %> pending</span><% } %>
                </div>
                <div class="card-meta">
                  <%= [e.date, e.event_time].filter(Boolean).join(' · ') || 'Date TBD' %> · <%= e.location || 'Location TBD' %>
                </div>
                <div class="card-stats">
                  <span>📋 <%= e.taskCount %> tasks</span>
                  <span>🙋 <%= e.claimCount %> people</span>
                  <span><%= e.totalNeeded > 0 ? Math.round(e.totalClaimed / e.totalNeeded * 100) : 0 %>% filled</span>
                </div>
                <div class="progress-bar">
                  <div class="progress-fill" style="width:<%= e.totalNeeded > 0 ? Math.min(100, Math.round(e.totalClaimed / e.totalNeeded * 100)) : 0 %>%"></div>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>
